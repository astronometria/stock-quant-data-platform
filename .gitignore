# -------------------------------------------------------------------
# Python cache / build artifacts
# -------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# -------------------------------------------------------------------
# Virtual environments
# -------------------------------------------------------------------
.venv/
venv/
env/

# -------------------------------------------------------------------
# Environment files
# -------------------------------------------------------------------
.env
.env.*

# -------------------------------------------------------------------
# Local databases and generated runtime artifacts
# Important:
# - We keep the directory structure in git, but not the generated DB files.
# - The serving release artifacts are publish outputs, not source code.
# -------------------------------------------------------------------
*.duckdb
*.duckdb.wal
*.duckdb.tmp
data/build/*.duckdb
data/releases/*
!data/releases/.gitkeep
data/current

# -------------------------------------------------------------------
# Logs
# -------------------------------------------------------------------
logs/*
!logs/.gitkeep

# -------------------------------------------------------------------
# Test / coverage / tooling caches
# -------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# -------------------------------------------------------------------
# Packaging artifacts
# -------------------------------------------------------------------
build/
dist/
*.egg-info/

# -------------------------------------------------------------------
# IDE / OS noise
# -------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
